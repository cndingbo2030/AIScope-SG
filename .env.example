# Copy to .env and fill in locally. Never commit .env (see .gitignore).

# data.gov.sg Production API (header: x-api-key)
DATA_GOV_SG_API_KEY=

# Optional: override default wage dataset resource id (d_… from dataset URL)
# DATA_GOV_SG_RESOURCE_ID=d_ec5d0e4ebdd2baee2a5aa1322a3156a5

# Anthropic (scoring / insights / translate scripts)
# ANTHROPIC_API_KEY=
